##
Production config
##

[server]
host: "0.0.0.0"
port: 8080

[tls]
enabled: true

[database]
host: "localhost"
port: 5432
password: $DB_PASS ?? "devpass"

[users.*]
name: "admin"
role: "owner"

[users.*]
name: "editor"
role: "staff"

base: &defaults {
timeout: 30
retry: 3
}

worker: {
<<: *defaults
retry: 5
}

url: "http://${server.host}:${server.port}"